// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())

  routines  Routine[]
  workouts  Workout[]
  diets     Diet[]
  readings  Reading[]
}

model Routine {
  id        Int       @id @default(autoincrement())
  title     String
  date      DateTime
  completed Boolean   @default(false)
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
}

model Workout {
  id        Int       @id @default(autoincrement())
  name      String
  muscle    String
  sets      Int
  reps      Int
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
}

model Diet {
  id        Int       @id @default(autoincrement())
  mealType  String
  food      String
  calories  Int
  date      DateTime
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
}

model Reading {
  id        Int       @id @default(autoincrement())
  title     String
  author    String
  pages     Int
  progress  Int       @default(0)
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
}
